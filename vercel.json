{
  "version": 2,
  "builds": [
    {
      "src": "book_ur_seat/wsgi.py",
      "use": "@vercel/python",
      "config": {
        "maxLambdaSize": "15mb",
        "runtime": "python3.12"
      }
    },
    {
      "src": "staticfiles/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/static/(.*)",
      "dest": "staticfiles/$1",
      "headers": {
        "Cache-Control": "public, max-age=31536000, immutable"
      }
    },
    {
      "src": "/media/(.*)",
      "dest": "https://your-external-storage.com/media/$1",
      "status": 308
    },
    {
      "src": "/(.*)",
      "dest": "book_ur_seat/wsgi.py",
      "methods": ["GET", "POST", "PUT", "PATCH", "DELETE", "OPTIONS"]
    }
  ],
  "build": {
    "env": {
      "PYTHONPATH": ".",
      "DJANGO_SETTINGS_MODULE": "book_ur_seat.settings",
      "DISABLE_MIGRATIONS": "1",
      "PYTHON_VERSION": "3.12",
      "PGSSLMODE": "require"
    },
    "command": "python manage.py collectstatic --noinput"
  }
}